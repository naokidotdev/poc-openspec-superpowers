#!/bin/sh
# openspec/ は private submodule (naokidotdev/poc-openspec-superpowers-specs) への参照。
# スーパープロジェクト側のコミットには gitlink 参照 (openspec) の更新のみを許可し、
# openspec/ 配下の実体ファイルが直接ステージングされた場合はコミットを拒否する。

staged_openspec_files=$(git diff --cached --name-only --diff-filter=ACM | grep '^openspec/' || true)

if [ -z "$staged_openspec_files" ]; then
  exit 0
fi

cat <<EOF >&2
pre-commit: openspec/ 配下の実体ファイルがスーパープロジェクトに直接ステージングされています。

$staged_openspec_files

openspec/ は private submodule です。実体ファイルはスーパープロジェクトの git history に
残してはいけません。以下のいずれかで対処してください:
  1. git restore --staged <file> でステージングを取り消す
  2. openspec/ 側にコミットする場合は openspec/ を作業ディレクトリとして実行する
     (例: cd openspec && git add . && git commit && git push)

gitlink としての参照更新 (git add openspec) はこのチェックの対象外です。
EOF

exit 1
