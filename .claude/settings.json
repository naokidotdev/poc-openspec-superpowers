{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-cd-openspec.sh",
            "statusMessage": "openspec/ の cd 使用チェック中..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-openspec-detached-head.sh",
            "statusMessage": "openspec/ の detached HEAD チェック中..."
          }
        ]
      }
    ]
  }
}
